# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to Git.

# --- Django ---
DJANGO_SECRET_KEY=change-me-generate-a-new-one
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Ethereum (Sepolia testnet) ---
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
TOKEN_CONTRACT_ADDRESS=0xYourContractAddress
TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# The private key of the wallet that sends tokens.
# Use a dedicated TESTNET wallet. Never reuse a wallet that holds real funds.
TREASURY_PRIVATE_KEY=0xYourTestnetPrivateKey

# --- Etherscan ---
ETHERSCAN_API_URL=https://api-sepolia.etherscan.io/api
ETHERSCAN_API_KEY=YourEtherscanApiKey

# --- Token economics ---
TOKEN_DECIMALS=10
TOKEN_PRICE=10000
